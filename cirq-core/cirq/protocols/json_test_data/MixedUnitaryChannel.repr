[
    cirq.MixedUnitaryChannel(
        mixture=[
            (0.5, np.array([[1, 0], [0, 1]], dtype=np.dtype("int64"))),
            (0.5, np.array([[0, 1], [1, 0]], dtype=np.dtype("int64"))),
        ],
        key="flip",
    ),
    cirq.MixedUnitaryChannel(
        mixture=[
            (0.25, np.array([[(1 + 0j), 0j], [0j, (1 + 0j)]], dtype=np.dtype("complex64"))),
            (0.25, np.array([[0j, (1 + 0j)], [(1 + 0j), 0j]], dtype=np.dtype("complex64"))),
            (0.25, np.array([[0j, (-0 - 1j)], [1j, 0j]], dtype=np.dtype("complex64"))),
            (0.25, np.array([[(1 + 0j), 0j], [0j, (-1 + 0j)]], dtype=np.dtype("complex64"))),
        ]
    ),
]
